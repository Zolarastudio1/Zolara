# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ANON_KEY=your-anon-key

# SMS - Arkesel (Ghana SMS provider)
VITE_ARKESEL_API_KEY=your-arkesel-api-key

# Payments - Paystack
# Note: secret key goes in Supabase edge function secrets, NOT here
# PAYSTACK_SECRET_KEY is set via: supabase secrets set PAYSTACK_SECRET_KEY=...

# WhatsApp Business API (optional - not yet active)
VITE_WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
